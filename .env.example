# Copy to .env and fill in values. Never commit .env to git.

# =============================================================================
# PHASE 0-4 (local dev): Nebius AI Studio API
# Use this during agent development and tracing before the H100 VM is up.
# Points the agent at the hosted Qwen3 endpoint — no GPU required locally.
# =============================================================================

VLLM_BASE_URL=https://api.studio.nebius.ai/v1
VLLM_MODEL=Qwen/Qwen3-30B-A3B-Instruct-2507
# Nebius AI Studio API key (generate at studio.nebius.ai → API Keys)
LLM_API_KEY=

# =============================================================================
# PHASE 1 / 5 / 6 (Nebius Cloud H100 VM): local vLLM
# Comment out the Nebius Studio block above and uncomment this block when
# running against the actual vLLM instance on the H100 VM.
# =============================================================================

# VLLM_BASE_URL=http://localhost:8000/v1
# VLLM_MODEL=Qwen/Qwen3-30B-A3B-Instruct-2507
# LLM_API_KEY=not-needed

# HuggingFace token for pulling the model on the VM (huggingface.co/settings/tokens)
HF_TOKEN=

# =============================================================================
# Nebius Cloud — VM provisioning credentials
# Used by the Nebius CLI / scripts to provision the H100 VM.
# Get these from console.nebius.ai → IAM → Service Accounts / API Keys
# =============================================================================

# No NEBIUS_IAM_TOKEN needed — the nebius CLI authenticates from ~/.nebius/config.yaml.
# Run `~/.nebius/bin/nebius iam auth` once to configure it.
#
# Project ID shown in the Nebius console URL (/projects/<id>).
NEBIUS_PARENT_ID=
# Subnet ID for the VM (console → VPC → Subnets).
NEBIUS_SUBNET_ID=
# Path to the SSH private key injected into the VM via cloud-init.
SSH_PRIVATE_KEY_PATH=~/.ssh/id_ed25519

# =============================================================================
# Langfuse — agent tracing (Phase 4)
# Sign up at http://localhost:3001 after docker compose up,
# create a project, and paste the keys below.
# =============================================================================

LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3001
